<view class="container">
  <!-- 头部（精简：标题+昵称） -->
  <view class="header">
    <view class="title-row">
      <text class="title">燕云十六声</text>
      <text class="subtitle">百业十人本报名</text>
    </view>
    <view class="week-badge">{{weekLabel}}</view>
    <view class="pdt-note">{{pdtLabel}}</view>
    <view class="nickname-row">
      <text class="label">角色名</text>
      <input class="nickname-input" value="{{nicknameInput}}"
             bindinput="onNicknameInput" bindconfirm="saveNickname"
             placeholder="输入角色名" maxlength="12" />
      <view class="save-btn" bindtap="saveNickname"
            wx:if="{{nicknameInput !== nickname}}">保存</view>
      <view class="role-selector">
        <view class="role-dot output {{preferredRole === '输出' ? 'active' : ''}}"
              bindtap="setPreferredRole" data-role="输出">🔵 输出</view>
        <view class="role-dot linlin {{preferredRole === '霖霖' ? 'active' : ''}}"
              bindtap="setPreferredRole" data-role="霖霖">🟢 霖霖</view>
      </view>
    </view>
    <view class="header-rules">每周期限报一个时段 · 10人满开新车 · 时间已转为本地时区</view>
  </view>

  <!-- 我的状态卡片（增强版） -->
  <view class="status-card" wx:if="{{myRegistration}}">
    <view class="status-main">
      <text class="status-check">✅</text>
      <view class="status-info">
        <text class="status-line1">已报名 {{myRegistration.localDisplay}}</text>
        <view class="status-line2">
          <text>第{{myRegistration.carIndex + 1}}车</text>
        </view>
      </view>
    </view>
    <view class="status-actions">
      <view class="leave-btn" bindtap="handleLeave">退出</view>
    </view>
  </view>

  <!-- recurring 预约状态（该周还没实际 slot） -->
  <view class="status-card recurring-pending" wx:if="{{!myRegistration && recurringPending}}">
    <view class="status-main">
      <text class="status-check">🔄</text>
      <view class="status-info">
        <text class="status-line1">每周自动 {{recurringPendingDisplay}}</text>
        <view class="status-line2">
          <text>等待系统创建（每6小时检查）</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 入口按钮（未报名且窗口开放时显示） -->
  <view class="entry-buttons" wx:if="{{!myRegistration && !loading && selectedDayWindowOpen}}">
    <view class="entry-btn quick-join-btn" bindtap="openSignupModal" data-mode="quick">
      ⚡ 快速加入
    </view>
    <view class="entry-btn create-team-btn" bindtap="openSignupModal" data-mode="create">
      🚗 创建车队
    </view>
  </view>
  <!-- 报名窗口已截止提示 -->
  <view class="window-closed-hint" wx:if="{{!myRegistration && !loading && !selectedDayWindowOpen}}">
    <text>该周期报名已截止（周六 1AM PDT）</text>
  </view>

  <!-- 每周自动 -->
  <view class="recurring-bar {{isRecurring ? 'recurring-on' : 'recurring-off'}}">
    <view class="recurring-toggle" bindtap="toggleRecurring">
      <view class="toggle-dot {{isRecurring ? 'toggle-on' : ''}}">
        <view class="dot-inner"></view>
      </view>
      <text class="recurring-label">每周自动报名</text>
    </view>
    <text class="recurring-hint" wx:if="{{isRecurring && recurringLocalDisplay}}">{{recurringLocalDisplay}}</text>
    <text class="recurring-hint-off" wx:if="{{!isRecurring}}">关闭</text>
  </view>

  <!-- 日期选择 Tab Bar (滚动8天) -->
  <scroll-view class="day-tabs-scroll" scroll-x wx:if="{{!loading}}">
    <view class="day-tabs">
      <view class="day-tab {{item.windowIndex === selectedDay ? 'active' : ''}} {{myRegistrations[item.weekDate] && myRegistrations[item.weekDate].dayDate === item.dayDate && item.windowIndex !== selectedDay ? 'has-reg' : ''}} {{item.dayDate < pdtTodayStr ? 'past-day' : ''}}"
            wx:for="{{rollingDays}}" wx:key="windowIndex"
            bindtap="selectDay" data-day="{{item.windowIndex}}">
        <text class="day-tab-name">{{item.dayShort}}</text>
        <text class="day-tab-date">{{item.shortDate}}</text>
        <text class="day-tab-count" style="color: {{item.totalCount >= 20 ? '#f0b429' : item.totalCount > 0 ? '#3fb950' : '#484f58'}}">{{item.totalCount > 0 ? item.totalCount + '人' : '-'}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- 时段热度 Heatmap -->
  <view class="section-title" wx:if="{{!loading}}">📊 时段热度</view>
  <view class="heatmap" wx:if="{{!loading}}">
    <view class="heatmap-col" wx:for="{{heatmapData}}" wx:key="pdtHour"
          bindtap="toggleSlot" data-hour="{{item.pdtHour}}">
      <text class="heatmap-count">{{item.count}}</text>
      <view class="heatmap-bar {{item.tier}}" style="height: {{item.barH}}rpx"></view>
      <text class="heatmap-label">{{item.label}}</text>
    </view>
  </view>

  <!-- 推荐卡片（未报名时） -->
  <view class="recommend-card" wx:if="{{!myRegistration && recommendation}}">
    <text class="recommend-badge">💡 推荐加入</text>
    <text class="recommend-text">{{recommendation.display}} — 缺{{recommendation.neededCount}}名{{recommendation.neededRole}}!</text>
    <text class="recommend-detail">第{{recommendation.carIndex + 1}}车: {{recommendation.carCount}}/10</text>
    <view class="recommend-btn" bindtap="joinRecommend">
      以{{recommendation.neededRole === '霖霖' ? '🟢霖霖' : '🔵输出'}}加入
    </view>
  </view>

  <!-- 通知订阅 -->
  <view class="notify-bar" bindtap="subscribeNotify">
    <text class="notify-text">开启开车前30分钟提醒</text>
    <text class="notify-arrow">></text>
  </view>

  <!-- 加载中 -->
  <view class="loading-box" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 紧凑时段列表 -->
  <view class="section-title" wx:if="{{!loading}}">全部时段</view>
  <view class="time-slots" wx:if="{{!loading}}">
    <block wx:for="{{timeSlots}}" wx:key="pdtHour" wx:for-item="slot">
      <!-- Compact slot row -->
      <view class="slot-row {{slotMeta[slot.pdtHour].isHot ? 'slot-row-hot' : ''}} {{myRegistration && myRegistration.hour === slot.pdtHour && myRegistration.dayDate === rollingDays[selectedDay].dayDate ? 'slot-row-current' : ''}} {{expandedSlots[slot.pdtHour] ? 'slot-row-expanded' : ''}} {{slotMeta[slot.pdtHour].isPast ? 'slot-row-past' : ''}}"
            bindtap="toggleSlot" data-hour="{{slot.pdtHour}}">
        <view class="slot-row-left">
          <text class="slot-row-chevron">▸</text>
          <text class="slot-row-time">{{slot.display}}</text>
          <text class="slot-row-count" wx:if="{{slotsMap[slot.pdtHour]}}">{{slotsMap[slot.pdtHour].totalCount}}人</text>
          <text class="slot-row-hot-tag" wx:if="{{slotMeta[slot.pdtHour].isHot}}">HOT</text>
          <text class="slot-row-past-tag" wx:if="{{slotMeta[slot.pdtHour].isPast && !(myRegistration && myRegistration.hour === slot.pdtHour && myRegistration.dayDate === rollingDays[selectedDay].dayDate)}}">已过</text>
          <text class="current-badge-small" wx:if="{{myRegistration && myRegistration.hour === slot.pdtHour && myRegistration.dayDate === rollingDays[selectedDay].dayDate}}">当前</text>
        </view>
        <view class="slot-row-right" catchtap="preventBubble">
          <!-- Join / Create / Move buttons — 已过时段或窗口未开放时不显示 -->
          <view class="action-btn join-btn" catchtap="handleSlotJoin"
                data-hour="{{slot.pdtHour}}"
                wx:if="{{!slotMeta[slot.pdtHour].isPast && selectedDayWindowOpen && !myRegistration && !actionLoading && !slotMeta[slot.pdtHour].allFull}}">
            加入
          </view>
          <view class="action-btn create-btn" catchtap="createTeamAt"
                data-hour="{{slot.pdtHour}}"
                wx:if="{{!slotMeta[slot.pdtHour].isPast && selectedDayWindowOpen && !myRegistration && !actionLoading && slotMeta[slot.pdtHour].allFull}}">
            开新车
          </view>
          <view class="action-btn move-btn" catchtap="handleMove"
                data-hour="{{slot.pdtHour}}"
                wx:if="{{!slotMeta[slot.pdtHour].isPast && selectedDayWindowOpen && myRegistration && !(myRegistration.hour === slot.pdtHour && myRegistration.dayDate === rollingDays[selectedDay].dayDate) && !actionLoading}}">
            挪到这里
          </view>
        </view>
      </view>

      <!-- Expandable car details -->
      <view class="slot-cars" wx:if="{{expandedSlots[slot.pdtHour]}}">
        <block wx:if="{{slotsMap[slot.pdtHour] && slotsMap[slot.pdtHour].cars.length > 0}}">
          <view class="car-card {{car.full ? 'car-full' : ''}}"
                wx:for="{{slotsMap[slot.pdtHour].cars}}" wx:key="carIndex" wx:for-item="car">
            <view class="car-top">
              <text class="car-name">第{{car.carIndex + 1}}车{{car.leaderNick ? ' 👑' + car.leaderNick : ''}}</text>
              <text class="car-count">{{car.count}}/10</text>
            </view>
            <view class="car-bar">
              <view class="car-bar-fill {{car.full ? 'bar-full' : ''}}"
                    style="width: {{car.count * 10}}%"></view>
            </view>
            <text class="car-bar-text {{car.full ? 'bar-full-text' : ''}}">{{car.count * 10}}% — {{car.full ? '已满' : '还差' + (10 - car.count) + '人'}}</text>
            <view class="members">
              <!-- Leader first -->
              <block wx:for="{{car.members}}" wx:key="openid" wx:for-item="member">
                <view class="member-wrap" wx:if="{{member.isLeader}}">
                  <view class="member member-leader {{member.openid === openid ? 'member-me-leader' : ''}} {{member.role === '霖霖' ? 'role-linlin-leader' : 'role-output-leader'}}">
                    👑 {{member.nickname}}
                  </view>
                </view>
              </block>
              <!-- Regular + proxy members -->
              <block wx:for="{{car.members}}" wx:key="openid" wx:for-item="member">
                <view class="member-wrap" wx:if="{{!member.isLeader}}">
                  <view class="member {{member.openid === openid ? 'member-me' : ''}} {{member.role === '霖霖' ? 'role-linlin' : 'role-output'}} {{member.registeredBy ? 'member-proxy' : ''}}">
                    {{member.nickname}}{{member.registeredBy ? '*' : ''}}
                    <text class="proxy-remove"
                          wx:if="{{member.registeredBy === openid}}"
                          catchtap="handleRemoveProxy"
                          data-member-openid="{{member.openid}}"
                          data-member-nickname="{{member.nickname}}"
                          data-slot-id="{{car._id}}">×</text>
                  </view>
                </view>
              </block>
            </view>
          </view>
        </block>
        <view class="empty-hint" wx:else>
          <text>虚位以待</text>
        </view>
      </view>
    </block>
  </view>

  <!-- 默认名字确认弹窗（简化版） -->
  <view class="modal-overlay" wx:if="{{showNameConfirm}}" catchtap="confirmNameCancel">
    <view class="modal-card name-confirm-card" catchtap="preventBubble">
      <view class="modal-title">确认角色名</view>
      <view class="name-confirm-body">
        <text>你的角色名是 </text>
        <text class="name-highlight">{{nameConfirmTarget}}</text>
      </view>
      <view class="name-confirm-hint">建议修改为游戏内角色名，方便他人组队。</view>
      <view class="modal-actions">
        <view class="modal-cancel-btn" bindtap="confirmNameCancel">去改名</view>
        <view class="modal-confirm-btn" bindtap="confirmNameOk">继续报名</view>
      </view>
    </view>
  </view>

  <!-- 规则已移到 header -->

  <!-- ===== 报名弹窗 ===== -->
  <view class="modal-overlay" wx:if="{{showSignupModal}}" bindtap="closeSignupModal">
    <view class="modal-card" catchtap="preventBubble">
      <!-- Modal title -->
      <view class="modal-title">
        <text wx:if="{{signupMode === 'quick'}}">⚡ 快速加入</text>
        <text wx:if="{{signupMode === 'create'}}">🚗 创建车队</text>
      </view>

      <!-- Day picker -->
      <view class="modal-row">
        <text class="modal-label">日期</text>
        <picker mode="selector" range="{{dayPickerOptions}}" range-key="label"
                value="{{dayPickerIndex}}" bindchange="onDayPickerChange">
          <view class="modal-picker">
            {{dayPickerOptions[dayPickerIndex].label}}
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>

      <!-- Hour picker -->
      <view class="modal-row">
        <text class="modal-label">时段</text>
        <picker mode="selector" range="{{hourPickerOptions}}" range-key="label"
                value="{{timePickerIndex}}" bindchange="onTimePickerChange">
          <view class="modal-picker">
            {{hourPickerOptions[timePickerIndex].label}}
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>

      <!-- Role selection -->
      <view class="modal-row">
        <text class="modal-label">职业</text>
        <view class="role-buttons">
          <view class="role-btn {{signupRole === '输出' ? 'role-btn-output-active' : 'role-btn-output'}}"
                bindtap="selectRole" data-role="输出">
            🔵 输出
          </view>
          <view class="role-btn {{signupRole === '霖霖' ? 'role-btn-linlin-active' : 'role-btn-linlin'}}"
                bindtap="selectRole" data-role="霖霖">
            🟢 霖霖
          </view>
        </view>
      </view>

      <!-- Recurring checkbox -->
      <view class="modal-row recurring-check" bindtap="toggleSignupRecurring">
        <view class="checkbox-box {{signupRecurring ? 'checkbox-checked' : ''}}">
          <text wx:if="{{signupRecurring}}">✓</text>
        </view>
        <text class="recurring-check-label">每周自动</text>
      </view>

      <!-- 帮别人报名（移到弹窗内） -->
      <view class="modal-section">
        <text class="modal-section-title">帮别人一起报名（可选）</text>
        <view class="extra-tags" wx:if="{{proxyList.length > 0}}">
          <view class="extra-tag {{item.role === '霖霖' ? 'extra-tag-linlin' : 'extra-tag-output'}}"
                wx:for="{{proxyList}}" wx:key="index">
            {{item.nickname}} {{item.role === '霖霖' ? '🟢' : '🔵'}}
            <text class="extra-remove" catchtap="removeProxyFromList" data-index="{{index}}">×</text>
          </view>
        </view>
        <view class="proxy-input-row">
          <input class="proxy-name-input" placeholder="朋友名字" maxlength="12"
                 value="{{proxyNameInput}}" bindinput="onProxyNameInput" />
          <picker class="proxy-role-picker" bindchange="onProxyRoleChange"
                  range="{{['🔵 输出', '🟢 霖霖']}}" value="{{proxyRoleIndex}}">
            <view class="proxy-role-display">{{proxyRoleIndex === 1 ? '🟢 霖霖' : '🔵 输出'}}</view>
          </picker>
          <view class="proxy-add-btn" bindtap="addProxyToList">+</view>
        </view>
      </view>

      <!-- Action buttons -->
      <view class="modal-actions">
        <view class="modal-cancel-btn" bindtap="closeSignupModal">取消</view>
        <view class="modal-confirm-btn {{actionLoading ? 'btn-disabled' : ''}}" bindtap="submitSignup">
          {{signupMode === 'quick' ? '加入' : '创建车队'}}
        </view>
      </view>
    </view>
  </view>
</view>
