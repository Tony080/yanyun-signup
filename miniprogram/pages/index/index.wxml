<view class="container">
  <!-- 头部信息 -->
  <view class="header">
    <view class="title-row">
      <text class="title">燕云十六声</text>
      <text class="subtitle">百业十人本报名</text>
    </view>
    <view class="week-badge">{{weekLabel}}</view>
    <view class="pdt-note">{{pdtLabel}}</view>
    <view class="nickname-row">
      <text class="label">角色名</text>
      <input class="nickname-input" value="{{nicknameInput}}"
             bindinput="onNicknameInput" bindconfirm="saveNickname"
             placeholder="输入角色名" maxlength="12" />
      <view class="save-btn" bindtap="saveNickname"
            wx:if="{{nicknameInput !== nickname}}">保存</view>
    </view>

    <!-- 帮别人报名（常驻 header） -->
    <view class="proxy-section">
      <view class="proxy-title">帮别人报名</view>
      <view class="proxy-tags" wx:if="{{proxyList.length > 0}}">
        <view class="proxy-tag {{item.role === '霖霖' ? 'proxy-tag-linlin' : 'proxy-tag-output'}}"
              wx:for="{{proxyList}}" wx:key="index">
          {{item.nickname}} {{item.role === '霖霖' ? '🟢' : '🔵'}}
          <text class="proxy-tag-x" catchtap="removeProxyFromList" data-index="{{index}}">×</text>
        </view>
      </view>
      <view class="proxy-input-row">
        <input class="proxy-name-input" placeholder="名字" maxlength="12"
               value="{{proxyNameInput}}" bindinput="onProxyNameInput" />
        <picker class="proxy-role-picker" bindchange="onProxyRoleChange"
                range="{{['🔵 输出', '🟢 霖霖']}}" value="{{proxyRoleIndex}}">
          <view class="proxy-role-display">{{proxyRoleIndex === 1 ? '🟢 霖霖' : '🔵 输出'}}</view>
        </picker>
        <view class="proxy-add-btn" bindtap="addProxyToList">+</view>
      </view>
    </view>
  </view>

  <!-- 入口按钮（未报名时显示） -->
  <view class="entry-buttons" wx:if="{{!myRegistration && !loading}}">
    <view class="entry-btn quick-join-btn" bindtap="openSignupModal" data-mode="quick">
      ⚡ 快速加入
    </view>
    <view class="entry-btn create-team-btn" bindtap="openSignupModal" data-mode="create">
      🚗 创建车队
    </view>
  </view>

  <!-- 我的报名状态 -->
  <view class="my-status" wx:if="{{myRegistration}}">
    <view class="status-top">
      <view class="status-left">
        <text class="status-icon">✅</text>
        <text class="status-text">已报名 {{myRegistration.localDisplay}} 第{{myRegistration.carIndex + 1}}车</text>
      </view>
      <view class="leave-btn" bindtap="handleLeave">退出</view>
    </view>
  </view>

  <!-- 每周自动 -->
  <view class="recurring-bar {{isRecurring ? 'recurring-on' : 'recurring-off'}}">
    <view class="recurring-toggle" bindtap="toggleRecurring">
      <view class="toggle-dot {{isRecurring ? 'toggle-on' : ''}}">
        <view class="dot-inner"></view>
      </view>
      <text class="recurring-label">每周自动报名</text>
    </view>
    <text class="recurring-hint" wx:if="{{isRecurring && recurringLocalDisplay}}">{{recurringLocalDisplay}}</text>
    <text class="recurring-hint-off" wx:if="{{!isRecurring}}">关闭</text>
  </view>

  <!-- 通知订阅 -->
  <view class="notify-bar" bindtap="subscribeNotify">
    <text class="notify-text">开启开车前30分钟提醒</text>
    <text class="notify-arrow">></text>
  </view>

  <!-- 加载中 -->
  <view class="loading-box" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 时间段列表 -->
  <view class="time-slots" wx:if="{{!loading}}">
    <view class="slot-block" wx:for="{{timeSlots}}" wx:key="pdtHour" wx:for-item="slot">
      <view class="slot-header">
        <view class="hour-info">
          <text class="hour-text">{{slot.display}}</text>
          <text class="total-count" wx:if="{{slotsMap[slot.pdtHour]}}">
            {{slotsMap[slot.pdtHour].totalCount}}人
          </text>
        </view>
        <view class="slot-actions">
          <!-- Per-slot join button (when not registered) -->
          <view class="action-btn join-btn" bindtap="handleSlotJoin"
                data-hour="{{slot.pdtHour}}" wx:if="{{!myRegistration && !actionLoading}}">
            加入
          </view>
          <!-- Move button (when registered in different slot) -->
          <view class="action-btn move-btn" bindtap="handleMove"
                data-hour="{{slot.pdtHour}}"
                wx:if="{{myRegistration && myRegistration.hour !== slot.pdtHour && !actionLoading}}">
            挪到这里
          </view>
          <!-- Current badge -->
          <view class="current-badge"
                wx:if="{{myRegistration && myRegistration.hour === slot.pdtHour}}">
            当前
          </view>
        </view>
      </view>

      <view class="cars-area">
        <block wx:if="{{slotsMap[slot.pdtHour] && slotsMap[slot.pdtHour].cars.length > 0}}">
          <view class="car-card {{car.full ? 'car-full' : ''}}"
                wx:for="{{slotsMap[slot.pdtHour].cars}}" wx:key="carIndex" wx:for-item="car">
            <view class="car-top">
              <text class="car-name">第{{car.carIndex + 1}}车{{car.leaderNick ? ' 👑' + car.leaderNick : ''}}</text>
              <text class="car-count">{{car.count}}/10</text>
            </view>
            <view class="car-bar">
              <view class="car-bar-fill {{car.full ? 'bar-full' : ''}}"
                    style="width: {{car.count * 10}}%"></view>
            </view>
            <view class="members">
              <!-- Leader first -->
              <block wx:for="{{car.members}}" wx:key="openid" wx:for-item="member">
                <view class="member-wrap" wx:if="{{member.isLeader}}">
                  <view class="member member-leader {{member.openid === openid ? 'member-me-leader' : ''}} {{member.role === '霖霖' ? 'role-linlin-leader' : 'role-output-leader'}}">
                    👑 {{member.nickname}}
                  </view>
                </view>
              </block>
              <!-- Regular + proxy members -->
              <block wx:for="{{car.members}}" wx:key="openid" wx:for-item="member">
                <view class="member-wrap" wx:if="{{!member.isLeader}}">
                  <view class="member {{member.openid === openid ? 'member-me' : ''}} {{member.role === '霖霖' ? 'role-linlin' : 'role-output'}} {{member.registeredBy ? 'member-proxy' : ''}}">
                    {{member.nickname}}{{member.registeredBy ? '*' : ''}}
                    <text class="proxy-remove"
                          wx:if="{{member.registeredBy === openid}}"
                          catchtap="handleRemoveProxy"
                          data-member-openid="{{member.openid}}"
                          data-member-nickname="{{member.nickname}}"
                          data-slot-id="{{car._id}}">×</text>
                  </view>
                </view>
              </block>
            </view>
          </view>
        </block>
        <view class="empty-hint" wx:else>
          <text>虚位以待</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 默认名字确认弹窗 -->
  <view class="modal-overlay" wx:if="{{showNameConfirm}}" catchtap="confirmNameCancel">
    <view class="modal-card name-confirm-card" catchtap="preventBubble">
      <view class="modal-title">确认角色名</view>
      <view class="name-confirm-body">
        <text>你确定使用 </text>
        <text class="name-highlight">{{nameConfirmTarget}}</text>
        <text class="copy-icon" catchtap="copyNameConfirm"> 📋</text>
        <text> 作为你的角色名报名吗？</text>
      </view>
      <view class="name-confirm-hint">请提供角色名以方便他人组队。</view>
      <view class="name-confirm-hint">请在下方输入你的名字确认：</view>
      <input class="name-confirm-input" value="{{nameConfirmInput}}"
             bindinput="onNameConfirmInput" placeholder="输入上面的名字确认" />
      <view class="modal-actions">
        <view class="modal-cancel-btn" bindtap="confirmNameCancel">取消，我去改名</view>
        <view class="modal-confirm-btn {{nameConfirmOk ? '' : 'modal-btn-disabled'}}"
              bindtap="confirmNameOk">确认使用</view>
      </view>
    </view>
  </view>

  <!-- 底部说明 -->
  <view class="footer">
    <text class="footer-text">每周自动刷新 | 每人每周限报一个时段 | 10人满开新车</text>
    <text class="footer-text">时间已自动转换为你的本地时区</text>
  </view>

  <!-- ===== 报名弹窗 ===== -->
  <view class="modal-overlay" wx:if="{{showSignupModal}}" bindtap="closeSignupModal">
    <view class="modal-card" catchtap="preventBubble">
      <!-- Modal title -->
      <view class="modal-title">
        <text wx:if="{{signupMode === 'quick'}}">⚡ 快速加入</text>
        <text wx:if="{{signupMode === 'create'}}">🚗 创建车队</text>
      </view>

      <!-- Time picker -->
      <view class="modal-row">
        <text class="modal-label">时段</text>
        <picker mode="selector" range="{{timePickerOptions}}" range-key="label"
                value="{{timePickerIndex}}" bindchange="onTimePickerChange">
          <view class="modal-picker">
            {{timePickerOptions[timePickerIndex].label}}
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>

      <!-- Role selection -->
      <view class="modal-row">
        <text class="modal-label">职业</text>
        <view class="role-buttons">
          <view class="role-btn {{signupRole === '输出' ? 'role-btn-output-active' : 'role-btn-output'}}"
                bindtap="selectRole" data-role="输出">
            🔵 输出
          </view>
          <view class="role-btn {{signupRole === '霖霖' ? 'role-btn-linlin-active' : 'role-btn-linlin'}}"
                bindtap="selectRole" data-role="霖霖">
            🟢 霖霖
          </view>
        </view>
      </view>

      <!-- Recurring checkbox -->
      <view class="modal-row recurring-check" bindtap="toggleSignupRecurring">
        <view class="checkbox-box {{signupRecurring ? 'checkbox-checked' : ''}}">
          <text wx:if="{{signupRecurring}}">✓</text>
        </view>
        <text class="recurring-check-label">每周自动</text>
      </view>

      <!-- Action buttons -->
      <view class="modal-actions">
        <view class="modal-cancel-btn" bindtap="closeSignupModal">取消</view>
        <view class="modal-confirm-btn {{actionLoading ? 'btn-disabled' : ''}}" bindtap="submitSignup">
          {{signupMode === 'quick' ? '加入' : '创建车队'}}
        </view>
      </view>
    </view>
  </view>
</view>
