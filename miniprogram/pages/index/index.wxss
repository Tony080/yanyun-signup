.container {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

/* ===== 头部 ===== */
.header {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(240, 180, 41, 0.15);
}

.title-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #f0b429;
}

.subtitle {
  font-size: 28rpx;
  color: #8b949e;
}

.week-badge {
  display: inline-block;
  background: rgba(240, 180, 41, 0.12);
  color: #f0b429;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  margin-bottom: 8rpx;
}

.pdt-note {
  font-size: 22rpx;
  color: #6e7681;
  margin-bottom: 20rpx;
}

.nickname-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.label {
  font-size: 26rpx;
  color: #8b949e;
  flex-shrink: 0;
}

.nickname-input {
  flex: 1;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 12rpx;
  padding: 12rpx 20rpx;
  color: #e6edf3;
  font-size: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.save-btn {
  flex-shrink: 0;
  background: #f0b429;
  color: #0d1117;
  padding: 10rpx 28rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: bold;
}

/* ===== 我的状态 ===== */
.my-status {
  background: rgba(35, 134, 54, 0.15);
  border: 1rpx solid rgba(35, 134, 54, 0.3);
  border-radius: 16rpx;
  padding: 20rpx 28rpx;
  margin-bottom: 20rpx;
}

.status-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.status-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.status-icon {
  color: #3fb950;
  font-size: 32rpx;
  font-weight: bold;
}

.status-text {
  color: #3fb950;
  font-size: 28rpx;
}

.leave-btn {
  background: rgba(248, 81, 73, 0.15);
  color: #f85149;
  padding: 10rpx 28rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  border: 1rpx solid rgba(248, 81, 73, 0.3);
  flex-shrink: 0;
}

/* ===== 每周自动 ===== */
.recurring-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-radius: 16rpx;
  padding: 18rpx 28rpx;
  margin-bottom: 20rpx;
}

.recurring-on {
  background: rgba(35, 134, 54, 0.1);
  border: 1rpx solid rgba(35, 134, 54, 0.25);
}

.recurring-off {
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid #21262d;
}

.recurring-hint-off {
  font-size: 22rpx;
  color: #484f58;
}

.recurring-toggle {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.toggle-dot {
  width: 44rpx;
  height: 26rpx;
  border-radius: 13rpx;
  background: #484f58;
  display: flex;
  align-items: center;
  padding: 0 3rpx;
  transition: background 0.2s;
}

.toggle-dot.toggle-on {
  background: #238636;
  justify-content: flex-end;
}

.dot-inner {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #ffffff;
}

.recurring-label {
  font-size: 24rpx;
  color: #c9d1d9;
}

.recurring-hint {
  font-size: 22rpx;
  color: #3fb950;
}

/* ===== 通知栏 ===== */
.notify-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(56, 139, 253, 0.08);
  border: 1rpx solid rgba(56, 139, 253, 0.2);
  border-radius: 16rpx;
  padding: 18rpx 28rpx;
  margin-bottom: 24rpx;
}

.notify-text {
  color: #58a6ff;
  font-size: 26rpx;
}

.notify-arrow {
  color: #58a6ff;
  font-size: 28rpx;
}

/* ===== 加载 ===== */
.loading-box {
  text-align: center;
  padding: 80rpx 0;
  color: #8b949e;
}

/* ===== 时间段 ===== */
.slot-block {
  margin-bottom: 28rpx;
}

.slot-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.hour-info {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.hour-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #e6edf3;
}

.total-count {
  font-size: 24rpx;
  color: #8b949e;
}

.slot-actions {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  padding: 10rpx 32rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.join-btn {
  background: #238636;
  color: #ffffff;
}

.move-btn {
  background: rgba(56, 139, 253, 0.15);
  color: #58a6ff;
  border: 1rpx solid rgba(56, 139, 253, 0.3);
}

.current-badge {
  background: rgba(240, 180, 41, 0.12);
  color: #f0b429;
  padding: 10rpx 24rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
}

/* ===== 车辆 ===== */
.cars-area {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.car-card {
  background: #161b22;
  border-radius: 16rpx;
  padding: 24rpx;
  border: 1rpx solid #21262d;
}

.car-card.car-full {
  border-color: rgba(240, 180, 41, 0.3);
  background: linear-gradient(135deg, #161b22 0%, rgba(240, 180, 41, 0.04) 100%);
}

.car-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.car-name {
  font-size: 26rpx;
  color: #8b949e;
}

.car-count {
  font-size: 24rpx;
  color: #8b949e;
}

.car-bar {
  height: 6rpx;
  background: #21262d;
  border-radius: 3rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
}

.car-bar-fill {
  height: 100%;
  background: #238636;
  border-radius: 3rpx;
  transition: width 0.3s;
}

.bar-full {
  background: #f0b429;
}

/* ===== 成员 ===== */
.members {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.member {
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  border: 1rpx solid transparent;
}

/* 输出=蓝色（默认） */
.role-output {
  background: rgba(56, 139, 253, 0.12);
  color: #79c0ff;
  border-color: rgba(56, 139, 253, 0.25);
}

/* 霖霖=绿色 */
.role-linlin {
  background: rgba(63, 185, 80, 0.12);
  color: #7ee787;
  border-color: rgba(63, 185, 80, 0.25);
}

/* 自己高亮边框 */
.member-me.role-output {
  background: rgba(56, 139, 253, 0.25);
  border-color: #58a6ff;
}

.member-me.role-linlin {
  background: rgba(63, 185, 80, 0.25);
  border-color: #3fb950;
}

/* ===== 空状态 ===== */
.empty-hint {
  text-align: center;
  padding: 32rpx;
  color: #484f58;
  font-size: 26rpx;
  background: #161b22;
  border-radius: 16rpx;
  border: 1rpx dashed #21262d;
}

/* ===== 底部 ===== */
.footer {
  text-align: center;
  padding: 40rpx 0 60rpx;
}

.footer-text {
  font-size: 22rpx;
  color: #484f58;
}
