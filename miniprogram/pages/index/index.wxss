.container {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

/* ===== 头部 ===== */
.header {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(240, 180, 41, 0.15);
}

.title-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #f0b429;
}

.subtitle {
  font-size: 28rpx;
  color: #8b949e;
}

.week-badge {
  display: inline-block;
  background: rgba(240, 180, 41, 0.12);
  color: #f0b429;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  margin-bottom: 8rpx;
}

.pdt-note {
  font-size: 22rpx;
  color: #6e7681;
  margin-bottom: 20rpx;
}

.nickname-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.label {
  font-size: 26rpx;
  color: #8b949e;
  flex-shrink: 0;
}

.nickname-input {
  flex: 1;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 12rpx;
  padding: 12rpx 20rpx;
  color: #e6edf3;
  font-size: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.save-btn {
  flex-shrink: 0;
  background: #f0b429;
  color: #0d1117;
  padding: 10rpx 28rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: bold;
}

/* ===== 职业记忆选择器 ===== */
.role-selector { display: flex; gap: 8rpx; flex-shrink: 0; }
.role-dot {
  padding: 8rpx 18rpx; border-radius: 12rpx; font-size: 22rpx; border: 2rpx solid transparent;
}
.role-dot.active { border-width: 2rpx; }
.header-rules { font-size: 20rpx; color: #484f58; margin-top: 16rpx; border-top: 1rpx solid rgba(255,255,255,0.04); padding-top: 12rpx; }

/* ===== Activity selector bar ===== */
.activity-bar {
  display: flex;
  white-space: nowrap;
  margin-bottom: 20rpx;
  padding: 8rpx 0;
}

.activity-item {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 12rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #8b949e;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid #21262d;
  flex-shrink: 0;
}

.activity-item.active {
  background: rgba(240, 180, 41, 0.15);
  color: #f0b429;
  border-color: rgba(240, 180, 41, 0.4);
  font-weight: 600;
}

.activity-add {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 12rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #58a6ff;
  background: rgba(56, 139, 253, 0.08);
  border: 1rpx dashed rgba(56, 139, 253, 0.3);
  flex-shrink: 0;
}

/* ===== 状态卡片（增强版）===== */
.status-card {
  background: rgba(35,134,54,0.12);
  border: 1rpx solid rgba(35,134,54,0.3);
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
}
.status-card.recurring-pending {
  background: rgba(56,139,253,0.1);
  border-color: rgba(56,139,253,0.3);
}
.status-main { display: flex; align-items: center; gap: 16rpx; margin-bottom: 12rpx; }
.status-check { font-size: 36rpx; }
.status-info { flex: 1; }
.status-line1 { color: #3fb950; font-size: 30rpx; font-weight: 600; }
.status-line2 { font-size: 24rpx; color: #8b949e; margin-top: 4rpx; }
.status-actions { display: flex; gap: 12rpx; }

/* ===== Day Tabs ===== */
.day-tabs-scroll {
  margin-bottom: 16rpx; white-space: nowrap;
}
.day-tabs {
  display: inline-flex; gap: 6rpx;
}
.day-tab {
  width: 110rpx; flex-shrink: 0; text-align: center; padding: 10rpx 0; border-radius: 12rpx;
  border: 2rpx solid #21262d; background: rgba(255,255,255,0.03);
}
.window-closed-hint {
  text-align: center; font-size: 24rpx; color: #6e7681;
  padding: 20rpx; margin-bottom: 16rpx;
  background: rgba(255,255,255,0.03); border-radius: 12rpx;
  border: 1rpx solid #21262d;
}
.day-tab.active { background: rgba(240,180,41,0.1); border-color: rgba(240,180,41,0.4); }
.day-tab.has-reg { background: rgba(35,134,54,0.08); border-color: rgba(35,134,54,0.3); }
.day-tab.past-day { opacity: 0.4; }
.day-tab-name { display: block; font-size: 26rpx; font-weight: 600; color: #c9d1d9; }
.day-tab.active .day-tab-name { color: #f0b429; }
.day-tab-date { display: block; font-size: 20rpx; color: #6e7681; margin-top: 2rpx; }
.day-tab-count { display: block; font-size: 20rpx; margin-top: 2rpx; }

/* ===== 时段热度 Heatmap ===== */
.section-title { font-size: 26rpx; color: #8b949e; font-weight: 600; margin-bottom: 16rpx; }
.heatmap {
  display: flex; gap: 6rpx; align-items: flex-end; height: 140rpx;
  margin-bottom: 24rpx;
}
.heatmap-col { flex: 1; display: flex; flex-direction: column; align-items: center; }
.heatmap-count { font-size: 20rpx; color: #8b949e; margin-bottom: 4rpx; }
.heatmap-bar { width: 100%; border-radius: 6rpx 6rpx 0 0; min-height: 8rpx; }
.heatmap-bar.tier-empty { background: #21262d; }
.heatmap-bar.tier-low { background: #238636; }
.heatmap-bar.tier-mid { background: #3fb950; }
.heatmap-bar.tier-hot { background: #f0b429; }
.heatmap-label { font-size: 20rpx; color: #6e7681; margin-top: 6rpx; }

/* ===== 推荐卡片 ===== */
.recommend-card {
  background: rgba(139,92,246,0.08);
  border: 1rpx solid rgba(139,92,246,0.25);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
}
.recommend-badge {
  display: inline-block; background: rgba(139,92,246,0.2); color: #a78bfa;
  padding: 4rpx 16rpx; border-radius: 8rpx; font-size: 22rpx; font-weight: 600; margin-bottom: 10rpx;
}
.recommend-text { font-size: 26rpx; color: #e6edf3; margin-bottom: 4rpx; }
.recommend-detail { font-size: 24rpx; color: #8b949e; margin-bottom: 16rpx; }
.recommend-btn {
  display: inline-block; border-radius: 12rpx;
  padding: 12rpx 32rpx; font-size: 24rpx; font-weight: bold;
}

/* ===== 紧凑时段行 ===== */
.slot-row {
  display: flex; align-items: center; justify-content: space-between;
  background: #161b22; border-radius: 14rpx; padding: 18rpx 24rpx; margin-bottom: 10rpx;
  border: 1rpx solid #21262d;
}
.slot-row-hot { border-color: rgba(240,180,41,0.25); }
.slot-row-current { border-color: rgba(35,134,54,0.4); }
.slot-row-left { display: flex; align-items: center; gap: 12rpx; flex: 1; }
.slot-row-time { font-size: 28rpx; font-weight: 600; color: #e6edf3; }
.slot-row-count { font-size: 24rpx; color: #8b949e; }
.slot-row-hot-tag { font-size: 20rpx; color: #f0b429; font-weight: bold; }
.slot-row-chevron { font-size: 24rpx; color: #484f58; transition: transform 0.2s; }
.slot-row-expanded .slot-row-chevron { transform: rotate(90deg); }
.slot-row-past { opacity: 0.5; }
.slot-row-past .slot-row-time { color: #484f58; }
.slot-row-past-tag { font-size: 20rpx; color: #484f58; margin-left: 6rpx; }
.current-badge-small { background: rgba(240,180,41,0.12); color: #f0b429; padding: 4rpx 14rpx; border-radius: 8rpx; font-size: 20rpx; }
.slot-row-right { flex-shrink: 0; }
.slot-cars { padding: 0 8rpx; margin-bottom: 16rpx; display: flex; flex-direction: column; gap: 16rpx; }
.create-btn {
  background: rgba(240,180,41,0.12); color: #f0b429; border: 1rpx solid rgba(240,180,41,0.3);
  padding: 10rpx 24rpx; border-radius: 12rpx; font-size: 24rpx; font-weight: bold;
}

/* ===== 帮报名输入（报名弹窗内） ===== */
.proxy-input-row { display: flex; gap: 10rpx; align-items: center; }
.proxy-name-input {
  flex: 1; background: rgba(255,255,255,0.06); border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: 10rpx; padding: 10rpx 16rpx; color: #e6edf3; font-size: 24rpx;
}
.proxy-role-picker { flex-shrink: 0; }
.proxy-role-display {
  background: rgba(255,255,255,0.06); border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: 10rpx; padding: 10rpx 16rpx; color: #e6edf3; font-size: 24rpx;
}
.proxy-add-btn {
  background: #238636; color: #fff; border-radius: 10rpx;
  width: 56rpx; height: 56rpx; display: flex; align-items: center;
  justify-content: center; font-size: 32rpx; font-weight: bold; flex-shrink: 0;
}

/* ===== 入口按钮 ===== */
.entry-buttons {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.entry-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.quick-join-btn {
  background: #238636;
  color: #ffffff;
}

.quick-join-btn:active {
  background: #1a6b2b;
}

.create-team-btn {
  background: transparent;
  color: #f0b429;
  border: 2rpx solid #f0b429;
}

.create-team-btn:active {
  background: rgba(240, 180, 41, 0.1);
}

/* ===== 我的状态 ===== */
.my-status {
  background: rgba(35, 134, 54, 0.15);
  border: 1rpx solid rgba(35, 134, 54, 0.3);
  border-radius: 16rpx;
  padding: 20rpx 28rpx;
  margin-bottom: 20rpx;
}

.status-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.status-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.status-icon {
  color: #3fb950;
  font-size: 32rpx;
  font-weight: bold;
}

.status-text {
  color: #3fb950;
  font-size: 28rpx;
}

.leave-btn {
  background: rgba(248, 81, 73, 0.15);
  color: #f85149;
  padding: 10rpx 28rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  border: 1rpx solid rgba(248, 81, 73, 0.3);
  flex-shrink: 0;
}

/* ===== 每周自动 ===== */
.recurring-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-radius: 16rpx;
  padding: 18rpx 28rpx;
  margin-bottom: 20rpx;
}

.recurring-on {
  background: rgba(35, 134, 54, 0.1);
  border: 1rpx solid rgba(35, 134, 54, 0.25);
}

.recurring-off {
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid #21262d;
}

.recurring-hint-off {
  font-size: 22rpx;
  color: #484f58;
}

.recurring-toggle {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.toggle-dot {
  width: 44rpx;
  height: 26rpx;
  border-radius: 13rpx;
  background: #484f58;
  display: flex;
  align-items: center;
  padding: 0 3rpx;
  transition: background 0.2s;
}

.toggle-dot.toggle-on {
  background: #238636;
  justify-content: flex-end;
}

.dot-inner {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #ffffff;
}

.recurring-label {
  font-size: 24rpx;
  color: #c9d1d9;
}

.recurring-hint {
  font-size: 22rpx;
  color: #3fb950;
}

/* ===== 通知栏 ===== */
.notify-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(56, 139, 253, 0.08);
  border: 1rpx solid rgba(56, 139, 253, 0.2);
  border-radius: 16rpx;
  padding: 18rpx 28rpx;
  margin-bottom: 24rpx;
}

.notify-text {
  color: #58a6ff;
  font-size: 26rpx;
}

.notify-arrow {
  color: #58a6ff;
  font-size: 28rpx;
}

/* ===== 加载 ===== */
.loading-box {
  text-align: center;
  padding: 80rpx 0;
  color: #8b949e;
}

/* ===== 时间段 ===== */
.slot-block {
  margin-bottom: 28rpx;
}

.slot-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.hour-info {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.hour-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #e6edf3;
}

.total-count {
  font-size: 24rpx;
  color: #8b949e;
}

.slot-actions {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  padding: 10rpx 32rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.join-btn {
  background: #238636;
  color: #ffffff;
}

.join-btn:active {
  background: #1a6b2b;
}

.move-btn {
  background: rgba(56, 139, 253, 0.15);
  color: #58a6ff;
  border: 1rpx solid rgba(56, 139, 253, 0.3);
}

.current-badge {
  background: rgba(240, 180, 41, 0.12);
  color: #f0b429;
  padding: 10rpx 24rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
}

/* ===== 车辆 ===== */
.cars-area {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.car-card {
  background: #161b22;
  border-radius: 16rpx;
  padding: 24rpx;
  border: 1rpx solid #21262d;
}

.car-card.car-full {
  border-color: rgba(240, 180, 41, 0.3);
  background: linear-gradient(135deg, #161b22 0%, rgba(240, 180, 41, 0.04) 100%);
}

.car-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.car-name {
  font-size: 26rpx;
  color: #8b949e;
}

.car-count {
  font-size: 24rpx;
  color: #8b949e;
}

.car-bar {
  height: 16rpx;
  background: #21262d;
  border-radius: 8rpx;
  margin-bottom: 8rpx;
  overflow: hidden;
}

.car-bar-fill {
  height: 100%;
  background: #238636;
  border-radius: 8rpx;
  transition: width 0.3s;
}

.bar-full {
  background: #f0b429;
}

.car-bar-text { font-size: 22rpx; color: #3fb950; margin-bottom: 12rpx; }
.bar-full-text { color: #f0b429; }

/* ===== 成员 ===== */
.members {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.member-wrap {
  display: inline-flex;
}

.member {
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  border: 1rpx solid transparent;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

/* Crown user (leader / special): bold + role color preserved via inline style */
.member-crown {
  font-weight: bold;
}

/* Proxy member */
.member-proxy {
  opacity: 0.9;
}

.proxy-remove {
  color: #f85149;
  font-size: 28rpx;
  font-weight: bold;
  margin-left: 4rpx;
  padding: 0 4rpx;
}

/* ===== 空状态 ===== */
.empty-hint {
  text-align: center;
  padding: 32rpx;
  color: #484f58;
  font-size: 26rpx;
  background: #161b22;
  border-radius: 16rpx;
  border: 1rpx dashed #21262d;
}

/* ===== 默认名字确认（简化版） ===== */
.name-confirm-card { max-width: 600rpx; }
.name-confirm-body { font-size: 28rpx; color: #c9d1d9; line-height: 1.6; margin-bottom: 16rpx; }
.name-highlight { color: #f0b429; font-weight: bold; font-size: 30rpx; }
.name-confirm-hint { font-size: 24rpx; color: #8b949e; margin-bottom: 16rpx; }

/* ===== 底部 ===== */
.footer {
  text-align: center;
  padding: 40rpx 0 60rpx;
}

.footer-text {
  font-size: 22rpx;
  color: #484f58;
}

/* ===== 报名弹窗 ===== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.65);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.modal-card {
  width: 100%;
  max-width: 640rpx;
  background: #161b22;
  border-radius: 24rpx;
  padding: 40rpx 36rpx;
  border: 1rpx solid #30363d;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.4);
}

.create-activity-card {
  max-height: 85vh;
  overflow-y: auto;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #e6edf3;
  margin-bottom: 32rpx;
  text-align: center;
}

.modal-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  gap: 16rpx;
}

.modal-row-block {
  margin-bottom: 24rpx;
}

.modal-label {
  font-size: 28rpx;
  color: #8b949e;
  flex-shrink: 0;
  width: 80rpx;
}

.modal-label-block {
  font-size: 28rpx;
  color: #8b949e;
  margin-bottom: 16rpx;
  display: block;
}

.modal-picker {
  flex: 1;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid #30363d;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  color: #e6edf3;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.modal-input {
  flex: 1;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid #30363d;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  color: #e6edf3;
  font-size: 26rpx;
}

.modal-input-short {
  flex: none;
  width: 160rpx;
}

.modal-hint-text {
  font-size: 24rpx;
  color: #8b949e;
}

.picker-arrow {
  color: #8b949e;
  font-size: 22rpx;
  margin-left: 12rpx;
}

/* Role buttons (dynamic) */
.role-buttons {
  display: flex;
  gap: 16rpx;
  flex: 1;
  flex-wrap: wrap;
}

.role-btn {
  flex: 1;
  min-width: 120rpx;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: bold;
  border: 2rpx solid transparent;
  background: rgba(255, 255, 255, 0.04);
}

.role-btn.role-active {
  background: rgba(255, 255, 255, 0.08);
}

/* Recurring checkbox */
.recurring-check {
  gap: 12rpx;
  padding: 8rpx 0;
}

.checkbox-box {
  width: 40rpx;
  height: 40rpx;
  border-radius: 8rpx;
  border: 2rpx solid #30363d;
  background: rgba(255, 255, 255, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #3fb950;
  font-size: 28rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.checkbox-checked {
  background: rgba(35, 134, 54, 0.3);
  border-color: #238636;
}

.recurring-check-label {
  font-size: 26rpx;
  color: #c9d1d9;
}

/* Proxy signup section */
.modal-section {
  margin-top: 8rpx;
  margin-bottom: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #21262d;
}

.modal-section-title {
  font-size: 24rpx;
  color: #8b949e;
  margin-bottom: 16rpx;
  display: block;
}

.extra-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.extra-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  background: rgba(255, 255, 255, 0.06);
  color: #c9d1d9;
  border: 1rpx solid #30363d;
}

.extra-remove {
  color: #f85149;
  font-size: 28rpx;
  font-weight: bold;
  padding: 0 4rpx;
  margin-left: 2rpx;
}

.extra-input-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.extra-name-input {
  flex: 1;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid #30363d;
  border-radius: 10rpx;
  padding: 12rpx 16rpx;
  color: #e6edf3;
  font-size: 24rpx;
}

.extra-role-toggle {
  display: flex;
  gap: 8rpx;
}

.extra-role-opt {
  width: 48rpx;
  height: 48rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 2rpx solid transparent;
}

.extra-add-btn {
  flex-shrink: 0;
  color: #58a6ff;
  font-size: 24rpx;
  font-weight: bold;
  padding: 12rpx 16rpx;
  background: rgba(56, 139, 253, 0.1);
  border-radius: 10rpx;
  border: 1rpx solid rgba(56, 139, 253, 0.3);
}

/* Modal action buttons */
.modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 12rpx;
}

.modal-cancel-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #8b949e;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid #30363d;
}

.modal-confirm-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: bold;
  color: #ffffff;
  background: #238636;
}

.modal-confirm-btn:active {
  background: #1a6b2b;
}

.btn-disabled {
  opacity: 0.5;
}

/* ===== Create Activity Modal extras ===== */

/* Role tags in create modal */
.role-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.role-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 600;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid;
}

.role-tag-remove {
  font-size: 28rpx;
  font-weight: bold;
  padding: 0 4rpx;
  margin-left: 4rpx;
  opacity: 0.7;
}

/* Role add row */
.role-add-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.role-add-input {
  flex: 1;
  min-width: 160rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid #30363d;
  border-radius: 10rpx;
  padding: 10rpx 16rpx;
  color: #e6edf3;
  font-size: 24rpx;
}

.color-palette {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.color-dot {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid transparent;
}

.color-dot-active {
  border-color: #ffffff;
  box-shadow: 0 0 0 2rpx rgba(255, 255, 255, 0.3);
}

.role-add-btn {
  background: #238636;
  color: #fff;
  border-radius: 10rpx;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  flex-shrink: 0;
}
